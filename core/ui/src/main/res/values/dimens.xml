<?xml version="1.0" encoding="utf-8"?>
<!--
    core:ui 统一尺寸规范（Design System）
    所有业务模块应引用此处定义的尺寸资源，确保视觉一致性。
-->
<resources>

    <!-- ==================== 间距（完整体系） ==================== -->
    <dimen name="spacing_1">1dp</dimen>
    <dimen name="spacing_2">2dp</dimen>
    <dimen name="spacing_4">4dp</dimen>
    <dimen name="spacing_8">8dp</dimen>
    <dimen name="spacing_12">12dp</dimen>
    <dimen name="spacing_16">16dp</dimen>
    <dimen name="spacing_20">20dp</dimen>
    <dimen name="spacing_24">24dp</dimen>
    <dimen name="spacing_32">32dp</dimen>
    <dimen name="spacing_48">48dp</dimen>

    <!-- ==================== 间距别名（兼容旧代码） ==================== -->
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_s">8dp</dimen>
    <dimen name="spacing_m">16dp</dimen>
    <dimen name="spacing_l">24dp</dimen>
    <dimen name="spacing_xl">32dp</dimen>

    <!-- ==================== 圆角（完整体系） ==================== -->
    <dimen name="radius_4">4dp</dimen>
    <dimen name="radius_8">8dp</dimen>
    <dimen name="radius_12">12dp</dimen>
    <dimen name="radius_16">16dp</dimen>
    <dimen name="radius_24">24dp</dimen>

    <!-- ==================== 圆角别名（兼容旧代码） ==================== -->
    <dimen name="radius_s">4dp</dimen>
    <dimen name="radius_m">8dp</dimen>
    <dimen name="radius_l">16dp</dimen>
    <dimen name="radius_xl">24dp</dimen>

    <!-- ==================== 字体大小（完整体系） ==================== -->
    <dimen name="text_caption">12sp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_subtitle">16sp</dimen>
    <dimen name="text_title">18sp</dimen>
    <dimen name="text_headline">20sp</dimen>
    <dimen name="text_display">24sp</dimen>

    <!-- ==================== 字体大小别名（兼容旧代码） ==================== -->
    <dimen name="text_size_caption">12sp</dimen>
    <dimen name="text_size_body">14sp</dimen>
    <dimen name="text_size_title">18sp</dimen>
    <dimen name="text_size_headline">20sp</dimen>

    <!-- ==================== 对话框 ==================== -->
    <dimen name="dialog_corner_radius">16dp</dimen>
    <dimen name="dialog_padding">24dp</dimen>
    <dimen name="dialog_min_width">280dp</dimen>

    <!-- ==================== 分割线 ==================== -->
    <dimen name="divider_height">1dp</dimen>
    <dimen name="divider_inset">16dp</dimen>

    <!-- ==================== 角标 ==================== -->
    <dimen name="badge_size">18dp</dimen>
    <dimen name="badge_text_size">10sp</dimen>
    <dimen name="badge_dot_size">8dp</dimen>

    <!-- ==================== 按钮尺寸 ==================== -->
    <dimen name="button_height_large">48dp</dimen>
    <dimen name="button_height_medium">40dp</dimen>
    <dimen name="button_height_small">32dp</dimen>
    <dimen name="button_text_size_large">16sp</dimen>
    <dimen name="button_text_size_medium">14sp</dimen>
    <dimen name="button_text_size_small">12sp</dimen>
    <dimen name="button_horizontal_padding_large">24dp</dimen>
    <dimen name="button_horizontal_padding_medium">16dp</dimen>
    <dimen name="button_horizontal_padding_small">12dp</dimen>

    <!-- ==================== 圆角尺寸（按钮专用） ==================== -->
    <dimen name="radius_large">16dp</dimen>
    <dimen name="radius_medium">8dp</dimen>
    <dimen name="radius_small">4dp</dimen>

    <!-- ==================== 列表项 ==================== -->
    <dimen name="list_item_height">56dp</dimen>
    <dimen name="list_item_height_two_line">72dp</dimen>
    <dimen name="list_item_icon_size">24dp</dimen>
    <dimen name="list_item_padding_horizontal">16dp</dimen>
    <dimen name="list_item_spacing">12dp</dimen>

    <!-- ==================== 输入框 ==================== -->
    <dimen name="input_height">48dp</dimen>
    <dimen name="input_min_height">48dp</dimen>
    <dimen name="input_text_size">14sp</dimen>
    <dimen name="input_hint_text_size">14sp</dimen>
    <dimen name="input_corner_radius">8dp</dimen>

    <!-- ==================== 状态视图 ==================== -->
    <dimen name="state_icon_size">96dp</dimen>
    <dimen name="state_title_text_size">16sp</dimen>
    <dimen name="state_desc_text_size">14sp</dimen>
    <dimen name="state_spacing">16dp</dimen>

</resources>
