<?xml version="1.0" encoding="utf-8"?>
<!--
    core:ui 统一主题样式（Design System）
    业务模块的 Activity/Application 可继承此主题。
-->
<resources>

    <!-- ==================== 应用主题 ==================== -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorOnBackground">@color/on_secondary</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnError">@color/on_error</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Core.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Core.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Core.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Core.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Core.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Core.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Core.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Core.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Core.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Core.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Core.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Core.LabelSmall</item>
    </style>

    <!-- ==================== 全局文本样式（Design Tokens） ==================== -->
    <style name="TextAppearance.Core.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Core.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Core.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Core.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

</resources>
