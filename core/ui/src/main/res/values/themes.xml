<?xml version="1.0" encoding="utf-8"?>
<!--
    core:ui 主题定义（Design System）
    包含浅色和深色两套主题，所有颜色值通过 ?attr/ 引用实现动态换肤。
-->
<resources>

    <!-- ==================== 浅色主题 ==================== -->
    <style name="Theme.App.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_background</item>
        <item name="textColorPrimary">@color/on_surface</item>
        <item name="textColorSecondary">@color/on_background</item>
        <item name="dividerColor">@color/divider</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
    </style>

    <!-- ==================== 深色主题 ==================== -->
    <style name="Theme.App.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_background_dark</item>
        <item name="textColorPrimary">@color/on_surface_dark</item>
        <item name="textColorSecondary">@color/on_background_dark</item>
        <item name="dividerColor">@color/divider_dark</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
    </style>

    <!-- ==================== DayNight 主题（跟随系统） ==================== -->
    <style name="Theme.App.DayNight" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_background</item>
        <item name="textColorPrimary">@color/on_surface</item>
        <item name="textColorSecondary">@color/on_background</item>
        <item name="dividerColor">@color/divider</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
    </style>

</resources>
