<?xml version="1.0" encoding="utf-8"?>
<!--
    core:ui 统一颜色体系（Design System）
    所有业务模块应引用此处定义的颜色资源，确保视觉一致性。
    深色模式适配通过 values-night/ 目录覆盖。
-->
<resources>

    <!-- ==================== 主色系 ==================== -->
    <!-- 主色 -->
    <color name="primary">#1976D2</color>
    <!-- 主色变体（状态栏、深色强调） -->
    <color name="primary_variant">#1565C0</color>
    <!-- 次色（FAB、选中态） -->
    <color name="secondary">#FF6F00</color>
    <!-- 次色变体 -->
    <color name="secondary_variant">#E65100</color>

    <!-- ==================== 基础色 ==================== -->
    <!-- 背景色 -->
    <color name="background">#FAFAFA</color>
    <!-- 表面色（卡片、浮层） -->
    <color name="surface">#FFFFFF</color>
    <!-- 错误色 -->
    <color name="error">#D32F2F</color>

    <!-- ==================== 文本颜色 ==================== -->
    <!-- 一级文本（主色上） -->
    <color name="on_primary">#FFFFFF</color>
    <!-- 二级文本（背景上） -->
    <color name="on_secondary">#212121</color>
    <!-- 三级文本（辅助/禁用） -->
    <color name="on_background">#757575</color>
    <!-- 表面色上的文本 -->
    <color name="on_surface">#212121</color>
    <!-- 错误色上的文本 -->
    <color name="on_error">#FFFFFF</color>

    <!-- ==================== 功能色 ==================== -->
    <!-- 成功 -->
    <color name="success">#388E3C</color>
    <!-- 警告 -->
    <color name="warning">#F57C00</color>
    <!-- 信息 -->
    <color name="info">#0288D1</color>

    <!-- ==================== 语义化功能色（组件专用） ==================== -->
    <color name="colorSuccess">#388E3C</color>
    <color name="colorWarning">#F57C00</color>
    <color name="colorError">#D32F2F</color>
    <color name="colorInfo">#0288D1</color>
    <!-- 功能色上的文本 -->
    <color name="on_success">#FFFFFF</color>
    <color name="on_warning">#FFFFFF</color>
    <color name="on_info">#FFFFFF</color>

    <!-- ==================== 分割线/边框 ==================== -->
    <color name="divider">#E0E0E0</color>
    <color name="border">#BDBDBD</color>

    <!-- ==================== 骨架屏专用 ==================== -->
    <color name="skeleton_base">#E0E0E0</color>
    <color name="skeleton_highlight">#F5F5F5</color>

    <!-- ==================== 深色模式颜色 ==================== -->
    <color name="background_dark">#121212</color>
    <color name="surface_dark">#1E1E1E</color>
    <color name="on_surface_dark">#FFFFFF</color>
    <color name="on_background_dark">#B0B0B0</color>
    <color name="divider_dark">#323232</color>
    <color name="border_dark">#424242</color>

</resources>
