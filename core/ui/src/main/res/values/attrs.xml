<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ======================================== -->
    <!-- LoadingMask 自定义属性                    -->
    <!-- ======================================== -->
    <declare-styleable name="LoadingMask">
        <!-- 遮罩背景颜色（默认半透明黑色） -->
        <attr name="lm_maskColor" format="color" />
        <!-- 加载文字颜色 -->
        <attr name="lm_textColor" format="color" />
        <!-- 加载文字大小 -->
        <attr name="lm_textSize" format="dimension" />
        <!-- 进度条样式（引用系统或自定义 ProgressBar style） -->
        <attr name="lm_progressBarStyle" format="reference" />
        <!-- 默认显示文字 -->
        <attr name="lm_defaultText" format="string" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- StateLayout 自定义属性                    -->
    <!-- ======================================== -->
    <declare-styleable name="StateLayout">
        <!-- Loading 状态布局 -->
        <attr name="sl_loadingLayout" format="reference" />
        <!-- 空状态布局 -->
        <attr name="sl_emptyLayout" format="reference" />
        <!-- 错误状态布局 -->
        <attr name="sl_errorLayout" format="reference" />
        <!-- 空状态图标 -->
        <attr name="sl_emptyIcon" format="reference" />
        <!-- 空状态文字 -->
        <attr name="sl_emptyText" format="string" />
        <!-- 错误状态图标 -->
        <attr name="sl_errorIcon" format="reference" />
        <!-- 错误状态文字 -->
        <attr name="sl_errorText" format="string" />
        <!-- 初始状态（默认 loading） -->
        <attr name="sl_initialState" format="enum">
            <enum name="loading" value="0" />
            <enum name="content" value="1" />
            <enum name="empty" value="2" />
            <enum name="error" value="3" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- SkeletonLayout 自定义属性                 -->
    <!-- ======================================== -->
    <declare-styleable name="SkeletonLayout">
        <!-- 骨架屏背景色（灰色占位块） -->
        <attr name="sk_skeletonColor" format="color" />
        <!-- 闪烁高亮色 -->
        <attr name="sk_highlightColor" format="color" />
        <!-- 骨架屏圆角半径 -->
        <attr name="sk_cornerRadius" format="dimension" />
        <!-- 闪烁动画时长（毫秒） -->
        <attr name="sk_duration" format="integer" />
        <!-- 是否自动开始 -->
        <attr name="sk_autoStart" format="boolean" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- VeilRecyclerFrameView 自定义属性          -->
    <!-- ======================================== -->
    <declare-styleable name="VeilRecyclerFrameView">
        <!-- 骨架块基础色 -->
        <attr name="vrf_baseColor" format="color" />
        <!-- 高亮色 -->
        <attr name="vrf_highlightColor" format="color" />
        <!-- 圆角半径 -->
        <attr name="vrf_cornerRadius" format="dimension" />
        <!-- 微光动画时长（ms） -->
        <attr name="vrf_shimmerDuration" format="integer" />
        <!-- 骨架项数量 -->
        <attr name="vrf_itemCount" format="integer" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- BadgeView 自定义属性                     -->
    <!-- ======================================== -->
    <declare-styleable name="BadgeView">
        <!-- 角标背景色 -->
        <attr name="bv_badgeColor" format="color" />
        <!-- 角标文字颜色 -->
        <attr name="bv_textColor" format="color" />
        <!-- 角标文字大小 -->
        <attr name="bv_textSize" format="dimension" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- RoundImageView 自定义属性                -->
    <!-- ======================================== -->
    <declare-styleable name="RoundImageView">
        <!-- 圆角半径 -->
        <attr name="riv_radius" format="dimension" />
        <!-- 形状：rectangle(0) / circle(1) -->
        <attr name="riv_shape" format="enum">
            <enum name="rectangle" value="0" />
            <enum name="circle" value="1" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- FlowLayout 自定义属性                    -->
    <!-- ======================================== -->
    <declare-styleable name="FlowLayout">
        <!-- 水平间距 -->
        <attr name="fl_horizontalSpacing" format="dimension" />
        <!-- 垂直间距 -->
        <attr name="fl_verticalSpacing" format="dimension" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- 主题属性定义（Design Tokens）             -->
    <!-- ======================================== -->
    <attr name="colorPrimary" format="color" />
    <attr name="colorPrimaryDark" format="color" />
    <attr name="colorAccent" format="color" />
    <attr name="colorSurface" format="color" />
    <attr name="colorOnSurface" format="color" />
    <attr name="colorOnSurfaceVariant" format="color" />
    <attr name="textColorPrimary" format="color" />
    <attr name="textColorSecondary" format="color" />
    <!-- dividerColor 已移至 GlobalDivider styleable 中定义 -->
    <attr name="cardBackgroundColor" format="color" />

    <!-- ======================================== -->
    <!-- GlobalToolbar 自定义属性                 -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalToolbar">
        <!-- 是否显示返回按钮 -->
        <attr name="showBackButton" format="boolean" />
        <!-- 标题文字 -->
        <attr name="titleText" format="string" />
        <!-- 标题文字颜色 -->
        <attr name="titleTextColor" format="color" />
        <!-- 标题文字大小 -->
        <attr name="titleTextSize" format="dimension" />
        <!-- 是否显示底部阴影线 -->
        <attr name="showBottomDivider" format="boolean" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalBottomNav 自定义属性              -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalBottomNav">
        <!-- 是否显示标签文字 -->
        <attr name="showLabels" format="boolean" />
        <!-- 选中图标颜色 -->
        <attr name="selectedIconColor" format="color" />
        <!-- 未选中图标颜色 -->
        <attr name="unselectedIconColor" format="color" />
        <!-- 选中文字颜色 -->
        <attr name="selectedTextColor" format="color" />
        <!-- 未选中文字颜色 -->
        <attr name="unselectedTextColor" format="color" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- 通用枚举属性（已被各组件 styleable 内联定义，此处保留仅供参考） -->
    <!-- ======================================== -->
    <!--
    <attr name="variant" format="enum">
        <enum name="primary" value="0" />
        <enum name="secondary" value="1" />
        <enum name="text" value="2" />
        <enum name="danger" value="3" />
    </attr>

    <attr name="buttonSize" format="enum">
        <enum name="large" value="0" />
        <enum name="medium" value="1" />
        <enum name="small" value="2" />
    </attr>

    <attr name="tailType" format="enum">
        <enum name="none" value="0" />
        <enum name="arrow" value="1" />
        <enum name="switch_compat" value="2" />
        <enum name="badge" value="3" />
    </attr>
    -->

    <!-- ======================================== -->
    <!-- GlobalButton 自定义属性                 -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalButton">
        <!-- 按钮变体 -->
        <attr name="variant" format="enum">
            <enum name="primary" value="0" />
            <enum name="secondary" value="1" />
            <enum name="text" value="2" />
            <enum name="danger" value="3" />
        </attr>
        <!-- 按钮尺寸 -->
        <attr name="buttonSize" format="enum">
            <enum name="large" value="0" />
            <enum name="medium" value="1" />
            <enum name="small" value="2" />
        </attr>
        <!-- 是否加载中 -->
        <attr name="loading" format="boolean" />
        <!-- 圆角半径 -->
        <attr name="cornerRadius" format="dimension" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalInputLayout 自定义属性            -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalInputLayout">
        <!-- 提示文字 -->
        <attr name="hint" format="string" />
        <!-- 是否显示清除按钮 -->
        <attr name="showClearButton" format="boolean" />
        <!-- 是否显示密码切换按钮 -->
        <attr name="showPasswordToggle" format="boolean" />
        <!-- 最大字数 -->
        <attr name="maxCount" format="integer" />
        <!-- 输入类型 -->
        <attr name="inputType" format="enum">
            <enum name="text" value="0" />
            <enum name="password" value="1" />
            <enum name="phone" value="2" />
            <enum name="number" value="3" />
            <enum name="email" value="4" />
            <enum name="multiline" value="5" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalListItem 自定义属性               -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalListItem">
        <!-- 左侧图标 -->
        <attr name="listIcon" format="reference" />
        <!-- 标题文字 -->
        <attr name="listTitle" format="string" />
        <!-- 副标题文字 -->
        <attr name="listSubtitle" format="string" />
        <!-- 尾部类型 -->
        <attr name="tailType" format="enum">
            <enum name="none" value="0" />
            <enum name="arrow" value="1" />
            <enum name="switch_compat" value="2" />
            <enum name="badge" value="3" />
        </attr>
        <!-- 是否显示分割线 -->
        <attr name="showDivider" format="boolean" />
        <!-- 尾部文字（如"未读"） -->
        <attr name="tailText" format="string" />
        <!-- 尾部角标数字 -->
        <attr name="tailBadgeCount" format="integer" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalStateView 自定义属性              -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalStateView">
        <!-- 空状态图标 -->
        <attr name="emptyIcon" format="reference" />
        <!-- 空状态文字 -->
        <attr name="emptyText" format="string" />
        <!-- 错误状态图标 -->
        <attr name="errorIcon" format="reference" />
        <!-- 错误状态文字 -->
        <attr name="errorText" format="string" />
        <!-- 超时状态图标 -->
        <attr name="timeoutIcon" format="reference" />
        <!-- 超时状态文字 -->
        <attr name="timeoutText" format="string" />
        <!-- 加载中文字 -->
        <attr name="loadingText" format="string" />
        <!-- 初始状态 -->
        <attr name="initialState" format="enum">
            <enum name="content" value="0" />
            <enum name="loading" value="1" />
            <enum name="empty" value="2" />
            <enum name="error" value="3" />
            <enum name="timeout" value="4" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalEmptyView 自定义属性              -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalEmptyView">
        <!-- 空状态类型 -->
        <attr name="emptyType" format="enum">
            <enum name="empty" value="0" />
            <enum name="error" value="1" />
            <enum name="no_result" value="2" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalTag 自定义属性                    -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalTag">
        <!-- 标签颜色 -->
        <attr name="tagColor" format="enum">
            <enum name="normal" value="0" />
            <enum name="primary" value="1" />
            <enum name="success" value="2" />
            <enum name="warning" value="3" />
            <enum name="error" value="4" />
        </attr>
        <!-- 标签大小 -->
        <attr name="tagSize" format="enum">
            <enum name="small" value="0" />
            <enum name="medium" value="1" />
            <enum name="large" value="2" />
        </attr>
        <!-- 标签文字 -->
        <attr name="tagText" format="string" />
        <!-- 是否可关闭 -->
        <attr name="closable" format="boolean" />
        <!-- 是否可选择 -->
        <attr name="selectable" format="boolean" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalBadge 自定义属性                  -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalBadge">
        <!-- 角标数字 -->
        <attr name="badgeCount" format="integer" />
        <!-- 角标位置 -->
        <attr name="badgePosition" format="enum">
            <enum name="topRight" value="0" />
            <enum name="topLeft" value="1" />
            <enum name="bottomRight" value="2" />
            <enum name="bottomLeft" value="3" />
        </attr>
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalDivider 自定义属性                -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalDivider">
        <!-- 分割线方向 -->
        <attr name="dividerOrientation" format="enum">
            <enum name="horizontal" value="0" />
            <enum name="vertical" value="1" />
        </attr>
        <!-- 左边距 -->
        <attr name="dividerInsetLeft" format="dimension" />
        <!-- 右边距 -->
        <attr name="dividerInsetRight" format="dimension" />
        <!-- 上边距 -->
        <attr name="dividerInsetTop" format="dimension" />
        <!-- 下边距 -->
        <attr name="dividerInsetBottom" format="dimension" />
        <!-- 分割线颜色（引用已有定义） -->
        <attr name="dividerColor" format="color" />
        <!-- 分割线厚度 -->
        <attr name="dividerThickness" format="dimension" />
    </declare-styleable>

    <!-- ======================================== -->
    <!-- GlobalAvatar 自定义属性                 -->
    <!-- ======================================== -->
    <declare-styleable name="GlobalAvatar">
        <!-- 头像形状 -->
        <attr name="avatarShape" format="enum">
            <enum name="circle" value="0" />
            <enum name="round" value="1" />
            <enum name="square" value="2" />
        </attr>
        <!-- 占位图 -->
        <attr name="avatarPlaceholder" format="reference" />
        <!-- 边框颜色 -->
        <attr name="avatarBorderColor" format="color" />
        <!-- 边框宽度 -->
        <attr name="avatarBorderWidth" format="dimension" />
        <!-- 状态 -->
        <attr name="avatarStatus" format="enum">
            <enum name="none" value="0" />
            <enum name="online" value="1" />
            <enum name="offline" value="2" />
            <enum name="busy" value="3" />
        </attr>
    </declare-styleable>

</resources>
