<?xml version="1.0" encoding="utf-8"?>
<!--
    core:ui 深色主题覆盖（Design System）
    当系统夜间模式开启时，此文件中的资源会覆盖 values/ 中的对应资源。
-->
<resources>

    <!-- ==================== DayNight 主题（跟随系统 - 深色） ==================== -->
    <style name="Theme.App.DayNight" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_background_dark</item>
        <item name="textColorPrimary">@color/on_surface_dark</item>
        <item name="textColorSecondary">@color/on_background_dark</item>
        <item name="dividerColor">@color/divider_dark</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
    </style>

</resources>
