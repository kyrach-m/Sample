<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        应用基础主题（纯 Compose 技术栈）
        继承自框架 Theme.Material.Light，仅提供 Activity 窗口基本属性。
        实际 UI 颜色由 Compose AppTheme 控制，XML 主题不影响 Compose 渲染。
    -->
    <style name="Theme.Sample" parent="@android:style/Theme.Material.Light.NoActionBar">
        <!-- 窗口背景透明，避免 Compose 渲染前系统背景色闪烁 -->
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!--
        闪屏页主题
        使用 androidx.core:core-splashscreen 官方库，系统自动处理自适应图标尺寸适配。
    -->
    <style name="Theme.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.Sample</item>
    </style>
</resources>
