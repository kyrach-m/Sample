<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 应用主题（夜间模式） -->
    <style name="Theme.Sample" parent="@android:style/Theme.Material.NoActionBar">
        <!-- 窗口背景色匹配 Compose 暗色主题，避免过渡期间黑屏 -->
        <item name="android:windowBackground">@color/window_background_light</item>
        <!-- 状态栏透明，配合 Compose enableEdgeToEdge() -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
